{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "he-prod-incen-health-adf-01"
		},
		"ls_adls_health_lake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_health_lake'"
		},
		"ls_databricks_perf_accessToken": {
			"type": "secureString",
			"metadata": "Secure string for 'accessToken' of 'ls_databricks_perf'"
		},
		"ls_pg_health_perf_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_pg_health_perf'"
		},
		"ls_adls_health_lake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://heprodincenhealthdl01.dfs.core.windows.net/"
		},
		"ls_pg_health_perf_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "localhost"
		},
		"ls_pg_health_perf_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "health_insurance_perf"
		},
		"ls_pg_health_perf_properties_typeProperties_username": {
			"type": "string",
			"defaultValue": "postgres"
		},
		"Full Load event driven_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/441c2aa2-0544-40d1-8840-96d8fc0e9801/resourceGroups/he-prod-incen-analytics-rg-01/providers/Microsoft.Storage/storageAccounts/heprodincenhealthdl01"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "he-prod-incen-health-adf-01_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adls_health_lake_accountKey": {
						"value": "[parameters('ls_adls_health_lake_accountKey')]"
					},
					"ls_databricks_perf_accessToken": {
						"value": "[parameters('ls_databricks_perf_accessToken')]"
					},
					"ls_pg_health_perf_password": {
						"value": "[parameters('ls_pg_health_perf_password')]"
					},
					"ls_adls_health_lake_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_health_lake_properties_typeProperties_url')]"
					},
					"ls_pg_health_perf_properties_typeProperties_server": {
						"value": "[parameters('ls_pg_health_perf_properties_typeProperties_server')]"
					},
					"ls_pg_health_perf_properties_typeProperties_database": {
						"value": "[parameters('ls_pg_health_perf_properties_typeProperties_database')]"
					},
					"ls_pg_health_perf_properties_typeProperties_username": {
						"value": "[parameters('ls_pg_health_perf_properties_typeProperties_username')]"
					},
					"Full Load event driven_properties_typeProperties_scope": {
						"value": "[parameters('Full Load event driven_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}