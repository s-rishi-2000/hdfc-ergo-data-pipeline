   "source": [
    "def is_palindrome(s):\n",
    "    s_clean = ''.join(c.lower() for c in s if c.isalnum())\n",
    "    return s_clean == s_clean[::-1]\n",
    "\n",
    "# Example usage\n",
    "example_string = \"A man, a plan, a canal: Panama\"\n",
    "result = is_palindrome(example_string)\n",
    "display(result)"
   ]
  }
